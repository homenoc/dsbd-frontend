    "@types/node": "^15.14.9",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "@types/redux-logger": "^3.0.13",
    "@types/sha.js": "^2.4.4",
    "buffer": "^6.0.3",
    "date-fns": "^2.30.0",
    "js-cookie": "^3.0.5",
    "moment": "^2.30.1",
    "notistack": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
