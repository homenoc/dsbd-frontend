{
  "name": "dsbd-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "HomeNOC frontend monorepo: apps/web (user), apps/admin, packages/shared",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "web": "pnpm --filter dsbd-web",
    "admin": "pnpm --filter dsbd-web-admin",
    "shared": "pnpm --filter @dsbd/shared",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "typescript": "~7.0.2",
    "vitest": "^4.1.10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
